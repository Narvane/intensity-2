# Copy to deploy/.env on the VPS (never commit .env)

# GHCR image — replace OWNER/REPO with your GitHub org/repo (lowercase)
API_IMAGE=ghcr.io/owner/intesity-2/api:latest

# Domains (must point to this VPS before first TLS issuance)
API_DOMAIN=api.intensity.example
APP_DOMAIN=app.intensity.example
ACME_EMAIL=ops@intensity.example

# PostgreSQL (generate strong passwords for production)
POSTGRES_DB=intensity
POSTGRES_USER=intensity
POSTGRES_PASSWORD=change-me-postgres

# JWT signing secret — at least 32 random characters
INTENSITY_JWT_SECRET=change-me-jwt-secret-at-least-32-chars

# Optional: shared secret for CI webhook (must match DEPLOY_WEBHOOK_SECRET in GitHub)
DEPLOY_WEBHOOK_SECRET=change-me-webhook-secret
